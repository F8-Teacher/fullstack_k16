generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  email String @unique @db.VarChar(100)
  name  String
  id    Int    @id @default(autoincrement())

  @@map("users")
}

model Post {
  id    Int     @id @default(autoincrement())
  title String? @db.VarChar(200)

  @@map("posts")
}

model Product {
  id   Int     @id @default(autoincrement())
  name String? @db.VarChar(200)

  @@map("products")
}
